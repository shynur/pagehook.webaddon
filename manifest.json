{
	"manifest_version": 3,
	"author": "谢骐",
	"homepage_url": "https://github.com/shynur",
	"developer": {
		"name": "谢骐",
		"url": "https://github.com/shynur"
	},
	"name": "Page Hook",
	"version": "0.1.2",
	"description": "将用户编写的 JavaScript 与 origin 关联, 页面每次加载完成时自动执行",
	"permissions": ["storage", "tabs"],
	"host_permissions": ["<all_urls>"],
	"action": {"default_popup": "popup.html"},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["dist/content_script.js"],
			"run_at": "document_idle"
		}
	]
}
